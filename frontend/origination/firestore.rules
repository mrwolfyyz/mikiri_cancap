rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check job ownership
    function isJobOwner(jobId) {
      return request.auth != null && 
             get(/databases/$(database)/documents/jobs/$(jobId)).data.user_id == request.auth.uid;
    }
    
    // Chat messages - ONLY collection affected by these rules
    // Only accessible by job owner (user_id must match)
    match /jobs/{jobId}/chat_messages/{messageId} {
      allow read, write: if isJobOwner(jobId);
    }
    
    // Job documents: owner only (prevents cross-tenant reads by job ID)
    // isJobOwner's get() on jobs/{jobId} uses this rule; backend uses Admin SDK and bypasses rules
    match /jobs/{jobId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      // No write rule - frontend should not write to jobs directly (goes through API Gateway)
    }
    
    // All other collections/paths are unaffected by these rules
    // If other collections exist, they will use their existing rules or default deny
    // Backend functions using Admin SDK bypass all rules
  }
}
