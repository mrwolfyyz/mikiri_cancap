# =============================================================================
# Skip Trace & Origination - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for local development/testing.
# For deployment, most values are managed by Terraform and Secret Manager.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
# Your GCP project ID (e.g., "my-project-123")
GCP_PROJECT=your-project-id

# GCP region for resource deployment
GCP_LOCATION=northamerica-northeast1
GCP_REGION=northamerica-northeast1

# -----------------------------------------------------------------------------
# Workflow Names
# -----------------------------------------------------------------------------
# These must match the workflow names deployed by Terraform
SKIPTRACE_WORKFLOW_NAME=investigate-skiptrace
ORIGINATION_WORKFLOW_NAME=investigate-origination

# -----------------------------------------------------------------------------
# Function URLs (Populated by Terraform - DO NOT HARDCODE)
# -----------------------------------------------------------------------------
# These are automatically set as environment variables on the API Gateway function
# by Terraform after the dependent functions are deployed.
# Leave blank here - they are for reference only.
CHAT_HANDLER_URL=
CHAT_HANDLER_ORIGINATION_URL=
ADDRESS_VERIFICATION_URL=

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# For development: "*" allows all origins
# For production: Restrict to your specific domains
# Example: "https://your-project-skiptrace.web.app,https://your-project-origination.web.app"
CORS_ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# API Keys (Managed via Secret Manager - NEVER store actual values here)
# -----------------------------------------------------------------------------
# These secrets are created by Terraform and values are set via gcloud CLI.
# They are accessed by functions at runtime from Secret Manager.
#
# Required secrets to configure after terraform apply:
# - HIBP_API_KEY             : Have I Been Pwned API key
#
# To set a secret value:
#   echo -n "your-api-key" | gcloud secrets versions add SECRET_NAME \
#     --data-file=- --project=$GCP_PROJECT

# -----------------------------------------------------------------------------
# Firebase Configuration (Generated by Terraform)
# -----------------------------------------------------------------------------
# Firebase configuration is automatically generated by Terraform and written to:
#   frontend/skiptrace/public/firebase-config.json
#   frontend/origination/public/firebase-config.json
#
# The frontend applications load this configuration at runtime.
# Do not manually create or edit these files.

# -----------------------------------------------------------------------------
# Local Development (Optional)
# -----------------------------------------------------------------------------
# For local testing with Firebase emulators
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
