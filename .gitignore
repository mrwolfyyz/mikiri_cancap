# =============================================================================
# Frontend Generated Files (from scripts/prepare-frontend.sh)
# =============================================================================
# These files are copied/generated from frontend/shared/ into platform dirs.
# The source of truth is frontend/shared/. Do NOT edit files in platform dirs.
