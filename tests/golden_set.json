{
  "_description": "Golden test cases for end-to-end integration testing. Each case defines an input and fuzzy assertions about what the system should find. These tests run against a live deployment and validate result quality.",
  "_usage": "python3 -m pytest tests/test_golden_set.py -v --golden-url=<API_GATEWAY_URL> --golden-token=<FIREBASE_TOKEN>",
  "cases": [
    {
      "id": "sari_cornfield",
      "description": "Interior designer in Toronto, strong public footprint, active social media, company director",
      "input": {
        "email": "saricornfield@rogers.com",
        "full_name": "Sari Cornfield",
        "city": "Toronto",
        "province": "ON",
        "company_name": "Haddington Developments"
      },
      "assertions": {
        "should_complete": true,
        "expect_phone_found": true,
        "expect_address_found": true,
        "expect_email_found": false,
        "expect_breaches_found": true,
        "expect_company_domain_resolved": true,
        "expect_social_profiles": ["linkedin", "facebook", "instagram"],
        "report_should_contain": ["Sari Cornfield", "Toronto", "Haddington"]
      }
    },
    {
      "id": "jacob_kinross",
      "description": "CanCap employee, younger person with social media, McGill grad, corporate email discoverable",
      "input": {
        "email": "jacob.kinross@gmail.com",
        "full_name": "Jacob Kinross",
        "city": "Toronto",
        "province": "ON",
        "company_name": "CanCap Group"
      },
      "assertions": {
        "should_complete": true,
        "expect_phone_found": false,
        "expect_address_found": false,
        "expect_email_found": true,
        "expect_breaches_found": true,
        "expect_company_domain_resolved": true,
        "expect_social_profiles": ["linkedin", "instagram"],
        "report_should_contain": ["Jacob Kinross", "Toronto", "CanCap"]
      }
    },
    {
      "id": "steven_leonoff",
      "description": "ARAMARK labour relations director, painter, large company, no breaches expected",
      "input": {
        "email": "steven.leonoff@gmail.com",
        "full_name": "Steven Leonoff",
        "city": "Toronto",
        "province": "ON",
        "company_name": "ARAMARK"
      },
      "assertions": {
        "should_complete": true,
        "expect_phone_found": false,
        "expect_address_found": false,
        "expect_email_found": false,
        "expect_breaches_found": false,
        "expect_company_domain_resolved": true,
        "expect_social_profiles": ["linkedin", "instagram"],
        "report_should_contain": ["Steven Leonoff", "Toronto", "ARAMARK"]
      }
    }
  ]
}
